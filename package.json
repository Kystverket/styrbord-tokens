{
  "name": "@kystverket/styrbord-tokens",
  "version": "0.6.3",
  "description": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kystverket/styrbord-tokens.git"
  },
  "exports": {
    ".": {
      "style": "./dist/kystverket.css"
    },
    "./colors": {
      "import": "./dist/color-tokens.js",
      "types": "./dist/color-tokens.d.ts"
    },
    "./*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "npx @digdir/designsystemet@1.16.1 tokens build -o dist && node scripts/build-ts-colors.mjs",
    "html": "npx @digdir/designsystemet@1.16.1 tokens build -o dist && node scripts/build-ts-colors.mjs && cd ds-demo-builder && npm install && npm run build"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@digdir/designsystemet-types": "1.16.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "glob": "^11.0.2",
    "tsx": "^4.19.3"
  }
}
